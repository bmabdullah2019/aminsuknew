APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=website
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=strict

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Domain Authorization / License Validation
#
# LICENSE_SERVER_VERIFY_URL should point to your central License Server endpoint:
#   POST /api/verify-license
LICENSE_SERVER_VERIFY_URL=

# Enable runtime domain/license enforcement (recommended true for production).
LICENSE_ENFORCEMENT_ENABLED=false

# This installation's license key (must match the domain record on the License Server).
LICENSE_KEY=

# Cache/Grace windows (seconds)
# - cache_ttl: how long we treat a successful validation as "fresh" (12–24h recommended)
# - grace_ttl: how long we can keep running if the license server is temporarily unreachable
LICENSE_CACHE_TTL_SECONDS=64800
LICENSE_GRACE_TTL_SECONDS=259200

# License server HTTP timeout (seconds)
LICENSE_SERVER_TIMEOUT_SECONDS=3

# Feature flags
FEATURE_PAYMENTS_HARDENED_VERIFICATION=true
FEATURE_ORDERS_STATE_MACHINE_ENFORCED=true
FEATURE_ORDERS_PHONE_CANCEL_AUTO_BLOCK_ENABLED=true
FEATURE_ORDERS_PHONE_CANCEL_BLOCK_THRESHOLD=3
FEATURE_ORDERS_RETURNED_STATUS_AUTO_RETURN_ENABLED=true
FEATURE_CHECKOUT_GUEST_OTP_REQUIRED=true
FEATURE_CHECKOUT_GUEST_OTP_VERIFICATION_WINDOW_SECONDS=1800
FEATURE_CHECKOUT_SERVER_BREAKDOWN_V2=true

# Reconciliation health check notifications (disabled by default)
RECONCILIATION_HEALTH_NOTIFICATIONS_ENABLED=false
RECONCILIATION_HEALTH_NOTIFICATION_CHANNELS=log
RECONCILIATION_HEALTH_NOTIFICATION_LOG_CHANNEL=stack
RECONCILIATION_HEALTH_NOTIFICATION_MAIL_TO=
RECONCILIATION_HEALTH_NOTIFICATION_SLACK_WEBHOOK_URL=
RECONCILIATION_HEALTH_NOTIFICATION_HTTP_TIMEOUT_SECONDS=5
RECONCILIATION_HEALTH_NOTIFICATION_DEDUPE_SECONDS=1800
RECONCILIATION_HEALTH_NOTIFICATION_CACHE_STORE=
RECONCILIATION_HEALTH_NOTIFICATION_CACHE_KEY_PREFIX=reconciliation:health:notify:

# Payment webhook authenticity (optional but recommended for production)
PAYMENT_WEBHOOK_MAX_SKEW_SECONDS=300
BKASH_WEBHOOK_SIGNATURE_SECRET=
BKASH_WEBHOOK_SIGNATURE_HEADER=X-Webhook-Signature
BKASH_WEBHOOK_TIMESTAMP_HEADER=X-Webhook-Timestamp
SHURJOPAY_WEBHOOK_SIGNATURE_SECRET=
SHURJOPAY_WEBHOOK_SIGNATURE_HEADER=X-Webhook-Signature
SHURJOPAY_WEBHOOK_TIMESTAMP_HEADER=X-Webhook-Timestamp

# BDCourier fraud checker
BDCOURIER_NAME="BDCourier Fraud API"
BDCOURIER_API_URL=https://api.bdcourier.com/courier-check
BDCOURIER_API_KEY=
BDCOURIER_QUERY_TYPE=basic
